    {
      "name": "gateway.product-updated",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "openpos.events.dlx",
        "x-dead-letter-routing-key": "dlq.gateway.product-updated"
      }
    },
    {
      "name": "openpos.events.dlq",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
