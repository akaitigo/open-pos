    {
      "name": "analytics.sale-completed",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "openpos.events.dlx",
        "x-dead-letter-routing-key": "dlq.analytics.sale-completed"
      }
    },
    {
      "name": "inventory.sale-voided",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "openpos.events.dlx",
        "x-dead-letter-routing-key": "dlq.inventory.sale-voided"
      }
    },
    {
      "name": "analytics.sale-voided",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
