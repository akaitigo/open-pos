# =============================================================================
# open-pos Docker Compose environment variables
# Copy to .env and adjust values: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# Used by: all backend services via DB_URL / DB_USER / DB_PASSWORD
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=openpos_dev

# -----------------------------------------------------------------------------
# RabbitMQ
# Used by: pos-service, inventory-service, analytics-service
# -----------------------------------------------------------------------------
RABBITMQ_DEFAULT_PASS=openpos_dev

# -----------------------------------------------------------------------------
# ORY Hydra (OAuth2/OIDC Provider)
# Used by: api-gateway (JWT verification), frontend apps (PKCE flow)
# -----------------------------------------------------------------------------
HYDRA_SECRETS_SYSTEM=openpos-hydra-secret-for-dev-only

# =============================================================================
# Backend service environment variables
# These are referenced as ${VAR:default} in application.properties.
# In local dev, defaults are sufficient. Override for Docker / production.
# =============================================================================

# --- Database (shared by all backend services) ---
# DB_URL=jdbc:postgresql://localhost:15432/openpos
# DB_USER=openpos
# DB_PASSWORD=openpos_dev

# --- Redis ---
# REDIS_URL=redis://localhost:16379

# --- RabbitMQ connection ---
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=15672
# RABBITMQ_USER=openpos
# RABBITMQ_PASS=openpos_dev

# --- ORY Hydra JWT ---
# HYDRA_JWKS_URL=http://localhost:14444/.well-known/jwks.json
# HYDRA_ISSUER=http://localhost:14444/

# --- gRPC service hosts (override for Docker networking) ---
# PRODUCT_SERVICE_HOST=localhost
# PRODUCT_SERVICE_PORT=9001
# STORE_SERVICE_HOST=localhost
# STORE_SERVICE_PORT=9002
# POS_SERVICE_HOST=localhost
# POS_SERVICE_PORT=9003
# INVENTORY_SERVICE_HOST=localhost
# INVENTORY_SERVICE_PORT=9004
# ANALYTICS_SERVICE_HOST=localhost
# ANALYTICS_SERVICE_PORT=9005

# --- HTTP / gRPC ports (override per service in Docker) ---
# QUARKUS_HTTP_PORT=8080
# QUARKUS_GRPC_SERVER_PORT=9001

# --- OpenTelemetry ---
# OTEL_ENDPOINT=http://localhost:4317

# =============================================================================
# Frontend environment variables (Vite: prefixed with VITE_)
# Set in apps/*/.env.local or inject at build time.
# =============================================================================

# --- Both apps (pos-terminal & admin-dashboard) ---
# VITE_API_URL=http://localhost:8080
# VITE_ORGANIZATION_ID=                     # UUID, auto-set by demo-config.json
# VITE_HYDRA_PUBLIC_URL=http://localhost:14444
# VITE_OIDC_CLIENT_ID=pos-terminal          # or admin-dashboard
# VITE_OIDC_REDIRECT_URI=http://localhost:5173/callback

# --- pos-terminal only ---
# VITE_DEFAULT_STORE_ID=                    # UUID, auto-set by demo-config.json
# VITE_DEFAULT_TERMINAL_ID=                 # UUID, auto-set by demo-config.json
