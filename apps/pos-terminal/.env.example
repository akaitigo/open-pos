# POS Terminal - Environment Variables
# Copy to .env.local and set values for your environment.

# API Gateway URL
VITE_API_URL=http://localhost:8080

# Organization ID (UUID) - required for multi-tenant context
VITE_ORGANIZATION_ID=

# ORY Hydra OIDC configuration
VITE_HYDRA_PUBLIC_URL=http://localhost:14444
VITE_OIDC_CLIENT_ID=pos-terminal
VITE_OIDC_REDIRECT_URI=http://localhost:5173/callback

# Default store/terminal IDs for demo mode (optional)
VITE_DEFAULT_STORE_ID=
VITE_DEFAULT_TERMINAL_ID=
