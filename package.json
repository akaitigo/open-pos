{
  "name": "open-pos",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/akaitigo/open-pos.git"
  },
  "author": "Ryusei Nakayama",
  "scripts": {
    "dev:pos": "pnpm --filter pos-terminal dev",
    "dev:admin": "pnpm --filter admin-dashboard dev",
    "demo:capture": "pnpm --filter e2e capture:readme-demo",
    "demo:gif": "bash scripts/render-demo-gif.sh",
    "demo:assets": "pnpm run demo:capture && pnpm run demo:gif",
    "build": "pnpm -r build",
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,jsx,json,css,md}\" \"packages/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,js,jsx,json,css,md}\" \"packages/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "pnpm run test:apps",
    "test:apps": "pnpm --filter @shared-types/openpos --filter pos-terminal --filter admin-dashboard test",
    "test:e2e": "pnpm --filter e2e test",
    "test:all": "pnpm run test:apps && pnpm run test:e2e",
    "e2e:install": "pnpm --filter e2e exec playwright install chromium",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.0",
    "prettier": "^3.8.0"
  },
  "pnpm": {
    "overrides": {
      "@rollup/plugin-terser": "1.0.0",
      "flatted": ">=3.4.2",
      "picomatch": ">=4.0.4",
      "undici": "7.24.1"
    }
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  }
}
